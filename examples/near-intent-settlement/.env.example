# ── near-intent-settlement example server ────────────────────────────────────
PORT=4021

# The Solvador facilitator (feat/near-intents-exact branch) with
# NEAR_INTENTS_EXACT=1 set in ITS .env. /verify and the nonce endpoint are open;
# /settle requires an API key.
FACILITATOR_URL=http://localhost:4022

# Solvador API key (dashboard → API keys). Sent as `x-api-key` on /settle only.
SOLVADOR_API_KEY=

# Merchant: the NEAR Intents account that receives the payment (transfer intent
# inside intents.near — named, ETH-implicit, or NEAR-implicit account id).
PAY_TO=solvador.near

# Price of GET /premium. "$0.01" (USD ≙ USDC, 6 dp). Keep it dust-sized while
# testing: this is MAINNET — every settlement moves real funds.
PRICE=$0.01

# Optional NEAR RPC override for the balance proxy (default keyless FastNEAR).
# NEAR_RPC_URL=
